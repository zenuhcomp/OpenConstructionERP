    "@types/three": "^0.183.1",
    "@xyflow/react": "^12.10.2",
    "ag-grid-community": "^32.3.0",
    "ag-grid-react": "^32.3.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
