{
  "name": "openestimate-frontend",
  "private": true,
  "version": "4.12.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:smoke": "playwright test smoke/",
    "test:e2e:report": "playwright show-report qa-report",
    "test:e2e:install": "playwright install chromium firefox webkit --with-deps",
    "lint": "eslint .",
    "lint:unicode": "node -e \"const fs=require('fs'),p=require('path');const re=/[\\u200B-\\u200F\\u2060-\\u2064\\u2066-\\u2069\\uFEFF]/;const skip=new Set(['node_modules','dist','build','coverage']);const allow=new Set([p.normalize('src/app/locales/ar.ts')]);let bad=[];function walk(d){for(const e of fs.readdirSync(d,{withFileTypes:true})){const f=p.join(d,e.name);if(e.isDirectory()){if(!skip.has(e.name))walk(f);}else if(/\\.(ts|tsx|js|jsx|css|html|md)$/.test(e.name)){const rel=p.relative(process.cwd(),f);if(allow.has(rel))continue;const t=fs.readFileSync(f,'utf8');if(re.test(t))bad.push(rel);}}}walk('src');if(bad.length){console.error('Zero-width Unicode found in:');bad.forEach(b=>console.error('  '+b));console.error('Run: python ../scripts/strip_zero_width.py');process.exit(1);}console.log('No zero-width Unicode characters found.');\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "api:generate": "openapi-typescript http://localhost:8000/api/openapi.json -o src/shared/lib/api-types.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.100.10",
    "@types/three": "^0.183.1",
    "@xyflow/react": "^12.10.2",
    "ag-grid-community": "^32.3.0",
    "ag-grid-react": "^32.3.9",
    "cesium": "^1.141.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "i18next": "^24.2.3",
    "isomorphic-dompurify": "^3.14.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.460.0",
    "maplibre-gl": "^5.24.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "react-map-gl": "^8.1.1",
    "react-resizable-panels": "^4.11.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.1",
    "three": "^0.183.2",
    "y-webrtc": "^10.3.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.9",
    "workbox-build": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "overrides": {
    "rollup": "4.59.0"
  }
}
