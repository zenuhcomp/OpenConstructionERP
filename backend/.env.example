# OpenConstructionERP — backend environment variables
# Copy this file to `backend/.env` and edit the values you need.
# Lines starting with `#` are comments; uncomment to override the default.

# ─── Database ─────────────────────────────────────────────────────────
# Default is SQLite stored at `./openestimate.db` (works out of the box).
# To use PostgreSQL, UNCOMMENT both lines below and edit credentials:
#
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/openestimate
# DATABASE_SYNC_URL=postgresql://user:password@localhost:5432/openestimate

# ─── Auth ─────────────────────────────────────────────────────────────
# JWT_SECRET MUST be a random 32+ character string in production.
# Generate with: `openssl rand -hex 32`
# (or `python -c "import secrets; print(secrets.token_urlsafe(32))"`).
# The backend refuses to boot in staging/production with a value shorter
# than 32 chars or matching any well-known default ("change-me",
# "secret", "jwt-secret", "openestimate-local-dev-key", etc.).
JWT_SECRET=openestimate-local-dev-key-CHANGE-ME

# ─── Vector search (AI Semantic Search for CWICR / Match Elements) ────
# Default backend is Qdrant. Install with:
#   pip install 'openconstructionerp[semantic]'   # qdrant-client
# To use the legacy LanceDB backend instead, install:
#   pip install 'openconstructionerp[vector]'     # lancedb
# and uncomment the line below.
# VECTOR_BACKEND=lancedb

# Qdrant server URL (only used when VECTOR_BACKEND=qdrant).
# QDRANT_URL=http://localhost:6333

# ─── Optional services ────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# ─── AI providers (optional — required for AI Chat / Cost Advisor) ────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Rate limiting (requests per minute) ──────────────────────────────
# API_RATE_LIMIT=100
# LOGIN_RATE_LIMIT=10
# AI_RATE_LIMIT=10

# ─── Demo seed ────────────────────────────────────────────────────────
# Set to false in production to skip seeding demo projects + accounts.
# SEED_DEMO=true

# ─── Demo account passwords (auto-generated if unset, persisted to
#     ~/.openestimator/.demo_credentials.json — set explicitly here to
#     keep the documented canonical demo creds working out of the box).
# DEMO_USER_PASSWORD=DemoPass1234!
# DEMO_ESTIMATOR_PASSWORD=DemoPass1234!
# DEMO_MANAGER_PASSWORD=DemoPass1234!
