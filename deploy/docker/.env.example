# OpenEstimate — Production Environment Variables
# Copy this file to .env and modify as needed.

# ── Application ──────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO

# ── Database (PostgreSQL for production) ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://oe:CHANGE_ME@localhost:5432/openestimate
DATABASE_SYNC_URL=postgresql://oe:CHANGE_ME@localhost:5432/openestimate
# DATABASE_POOL_SIZE=20
# DATABASE_MAX_OVERFLOW=10

# ── Auth (CHANGE THESE!) ────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
# JWT_EXPIRE_MINUTES=60
# JWT_REFRESH_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-domain.com

# ── Frontend Serving ─────────────────────────────────────────────────
# Set to true if backend should serve the React frontend directly.
# Set to false if using a separate Nginx/CDN for the frontend.
SERVE_FRONTEND=true

# ── Redis (optional — enables background tasks) ─────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Storage (S3/MinIO — optional, defaults to local filesystem) ─────
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=openestimate

# ── Vector Search ────────────────────────────────────────────────────
# Default: lancedb (embedded, no external service needed)
VECTOR_BACKEND=lancedb
# VECTOR_DATA_DIR=/data/vectors
#
# For Qdrant (production, requires separate Qdrant service):
# VECTOR_BACKEND=qdrant
# QDRANT_URL=http://localhost:6333

# ── Rate Limiting (requests per minute) ──────────────────────────────
# API_RATE_LIMIT=100
# LOGIN_RATE_LIMIT=10
# AI_RATE_LIMIT=10

# ── AI Providers (optional — features degrade gracefully) ────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── External Services (optional) ────────────────────────────────────
# CAD_CONVERTER_URL=http://localhost:8001
# CV_PIPELINE_URL=http://localhost:8002
